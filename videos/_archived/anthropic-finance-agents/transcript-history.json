  "inter_chunk_silence_ms": 650,
  "chunks": [
    {
      "index": 0,
      "text": "Anthropic just shipped agents for financial services.",
      "checksum": "sha256:0c1f2634259eacdfe01cebdd4c8abc3bca4ac58c6901cfab04ec30982c3f4ecd",
      "wav": "chunk-00.wav",
      "duration": 3.0650340136054424,
      "word_count": 7,
      "words_offset": 0
    },
    {
      "index": 1,
      "text": "This dropped today, May 5th. Ten ready-to-run templates for the most time-consuming work on Wall Street.",
      "checksum": "sha256:cc6e40a9dbeec800e10f0e8515b58beaeb014691d981ff1d6f5de2684e658b8c",
      "wav": "chunk-01.wav",
      "duration": 6.0836281179138325,
      "word_count": 16,
      "words_offset": 7
    },
    {
      "index": 2,
      "text": "From pitchbook building to credit memos to month-end closing.",
      "checksum": "sha256:ee4e8b9d98f0ecbd2f2e525d38ec40f2879de8f9880cc3aee328bd026276c142",
      "wav": "chunk-02.wav",
      "duration": 3.1579138321995464,
      "word_count": 9,
      "words_offset": 23
    },
    {
      "index": 3,
      "text": "Live in Claude Cowork. Live in Claude Code.",
      "checksum": "sha256:62727bf5592411e69533d89f12e6ba86f6238f9b06c7f2865e20f6eff04d47fe",
      "wav": "chunk-03.wav",
      "duration": 2.461315192743764,
      "word_count": 8,
      "words_offset": 32
    },
    {
      "index": 4,
      "text": "Plus cookbooks for Claude Managed Agents.",
      "checksum": "sha256:92593b1afaa1c6dca57e852a2c4b2b6c84f2d1143deaa0c0d0bc9c90e2d31040",
      "wav": "chunk-04.wav",
      "duration": 2.182675736961451,
      "word_count": 6,
      "words_offset": 40
    },
    {
      "index": 5,
      "text": "The lineup covers three categories. First, research and client coverage.",
      "checksum": "sha256:f2cacf5d749b958866909c1f530f3fac3286be5ad2d62a145b94f1f804c13ff4",
      "wav": "chunk-05.wav",
      "duration": 4.458231292517007,
      "word_count": 10,
      "words_offset": 46
    },
    {
      "index": 6,
      "text": "Pitch builder. Meeting preparer. Earnings reviewer.",
      "checksum": "sha256:fff748c3c9c63314682ca5329ba5efcced8b552f73ee5152a7d6bc2d65c51996",
      "wav": "chunk-06.wav",
      "duration": 3.01859410430839,
      "word_count": 6,
      "words_offset": 56
    },
    {
      "index": 7,
      "text": "Model builder. Then credit and compliance.",
      "checksum": "sha256:afc264fbe6218abbc5befbcf132e63491b12b90ad29f7ff748871434584258ff",
      "wav": "chunk-07.wav",
      "duration": 2.36843537414966,
      "word_count": 6,
      "words_offset": 62
    },
    {
      "index": 8,
      "text": "Market researcher. KYC screener. And finally, finance operations.",
      "checksum": "sha256:2fe108d1d882f767f9f9b8c02f6b3676dd1806a176f505aa3eec63b32be88bd6",
      "wav": "chunk-08.wav",
      "duration": 4.31891156462585,
      "word_count": 8,
      "words_offset": 68
    },
    {
      "index": 9,
      "text": "Valuation reviewer. General ledger reconciler.",
      "checksum": "sha256:8cdb3a5f13d552f06cdd33c2e4dd7b7dc884efba81c723261eee93dcf439b02c",
      "wav": "chunk-09.wav",
      "duration": 2.7399546485260773,
      "word_count": 5,
      "words_offset": 76
    },
    {
      "index": 10,
      "text": "Month-end closer. Statement auditor. Ten templates total.",
      "checksum": "sha256:d341abcbff14b84b0b22fbc556d3e20701d2212b875d09f5f74d8b83c81fd575",
      "wav": "chunk-10.wav",
      "duration": 3.7151927437641725,
      "word_count": 7,
      "words_offset": 81
    },
    {
      "index": 11,
      "text": "Claude now runs inside Microsoft 365. Excel for financial modeling and formula auditing.",
      "checksum": "sha256:1b7a845acbe7fa5d37e5d34828a0b24e12004bfd85d5f235c691c7e847df0b16",
      "wav": "chunk-11.wav",
      "duration": 5.340589569160998,
      "word_count": 13,
      "words_offset": 88
    },
    {
      "index": 12,
      "text": "PowerPoint for auto-updating decks. Word for credit memos.",
      "checksum": "sha256:ab14a479c932e849178c5e85e62f484427df730e545ad768cc8b71936adabb0d",
      "wav": "chunk-12.wav",
      "duration": 3.3901133786848074,
      "word_count": 8,
      "words_offset": 101
    },
    {
      "index": 13,
      "text": "Outlook is coming next, with inbox triage and response drafting.",
      "checksum": "sha256:276634744861e490313bd1fda9b4d0f195124bd87c47f3d60f8fc39e1333923f",
      "wav": "chunk-13.wav",
      "duration": 3.297233560090703,
      "word_count": 10,
      "words_offset": 109
    },
    {
      "index": 14,
      "text": "Context carries automatically between every app. The partner ecosystem just expanded too.",
      "checksum": "sha256:9a8d349b947a36a2c3564d1ad6c24935182db9e1c8c7fa5c206e32ab6e431537",
      "wav": "chunk-14.wav",
      "duration": 5.804988662131519,
      "word_count": 12,
      "words_offset": 119
    },
    {
      "index": 15,
      "text": "S and P, MSCI, PitchBook, Morningstar, LSEG, all connected through new add-ins.",
      "checksum": "sha256:c032cf67ec7718323bfd9882f71a8567feb0f433dfa6b8021bfc00993412e113",
      "wav": "chunk-15.wav",
      "duration": 5.6656689342403626,
      "word_count": 12,
      "words_offset": 131
    },
    {
      "index": 16,
      "text": "Plus an MCP app from Moody's covering 600 million companies of verified business data.",
      "checksum": "sha256:4d8795b26637a36e3dae42b4958369a813cfeb8ea10da10aeaffcb62d47e74ea",
      "wav": "chunk-16.wav",
      "duration": 5.015510204081632,
      "word_count": 14,
      "words_offset": 143
    },
    {
      "index": 17,
      "text": "Citadel is already shipping it. Their head of core engineering Atte Lahtiranta says Claude for Excel meets investment professionals exactly where they live, in data and in analytical models.",
      "checksum": "sha256:5fd1beba9064c22ede91bdfb092dcb9960db2d485d9dc012a048d65f07b2811b",
      "wav": "chunk-17.wav",
      "duration": 12.213696145124716,
      "word_count": 29,
      "words_offset": 157
    },
    {
      "index": 18,
      "text": "Analysts use it to build coverage models and separate signal from noise.",
      "checksum": "sha256:d28a7c6520eb2f514d35b0399804bebd046556e9607be72c6289dba5e2da83ec",
      "wav": "chunk-18.wav",
      "duration": 3.8545124716553287,
      "word_count": 12,
      "words_offset": 186
    },
    {
      "index": 19,
      "text": "This is from Anthropic's launch video. Watch the real workflow.",
      "checksum": "sha256:74bbcd6d84a1791b9303f8a80a1b8ce1e30ffaf55495e10d1c685ee230c76122",
      "wav": "chunk-19.wav",
      "duration": 3.4829931972789114,
      "word_count": 10,
      "words_offset": 198
    },
    {
      "index": 20,
      "text": "An analyst pulls the data. Claude reasons over the model.",
      "checksum": "sha256:61b2f54eabbfe91ad32ee6b5b5f3449cdc00c7e5fa79fc7810caa6f4715398cb",
      "wav": "chunk-20.wav",
      "duration": 3.436553287981859,
      "word_count": 10,
      "words_offset": 208
    },
    {
      "index": 21,
      "text": "The agent fills in the math. This is what just shipped today.",
      "checksum": "sha256:6386a9c73be519fc5b335a6be19ff7f36fe484caf054eb67d71aa95f3607fa2c",
      "wav": "chunk-21.wav",
      "duration": 3.01859410430839,
      "word_count": 12,
      "words_offset": 218
    },
    {
      "index": 22,
      "text": "FIS runs the rails for thousands of financial institutions worldwide.",
      "checksum": "sha256:c6d966074709bc7e2d893cf6edcc43d2a61c66c7cee8a99ec44ec16493025484",
      "wav": "chunk-22.wav",
      "duration": 3.8080725623582765,
      "word_count": 10,
      "words_offset": 230
    },
    {
      "index": 23,
      "text": "Their CEO Stephanie Ferris says they needed a provider they could trust.",
      "checksum": "sha256:83c9e5eccf803165afcf5f0abcf5c4b548155f0bd3001f72d81f8037941eed17",
      "wav": "chunk-23.wav",
      "duration": 4.08671201814059,
      "word_count": 12,
      "words_offset": 240
    },
    {
      "index": 24,
      "text": "Anthropic was the clear choice. Together, they are compressing AML investigations from days to minutes.",
      "checksum": "sha256:8ed2c8cda284c80c51dfc1293b8bcea4a233c4e9a279bcead84b2aad0f5d7853",
      "wav": "chunk-24.wav",
      "duration": 7.012426303854875,
      "word_count": 15,
      "words_offset": 252
    },
    {
      "index": 25,
      "text": "The receipts. Claude Opus 4.7 now leads the Vals AI Finance Agent benchmark at 64 percent.",
      "checksum": "sha256:09eb9c0e75756bfd72f500a703262596b9b9b579f3fac351491c4782d2decd13",
      "wav": "chunk-25.wav",
      "duration": 6.315827664399093,
      "word_count": 16,
      "words_offset": 267
    },
    {
      "index": 26,
      "text": "Carlyle adopted Claude as a core part of their AI tech stack.",
      "checksum": "sha256:a6a5cc5573ce5df0c09b05fdb765504762f66b8631c92707fc90b15e829bdb2f",
      "wav": "chunk-26.wav",
      "duration": 3.3901133786848074,
      "word_count": 12,
      "words_offset": 283
    },
    {
      "index": 27,
      "text": "BNY uses it as digital employees that handle entire cases end to end.",
      "checksum": "sha256:e53242336330bdad4aa8e77a69464958d47816c8caebd66cdf2bab191fd9dccb",
      "wav": "chunk-27.wav",
      "duration": 4.504671201814059,
      "word_count": 13,
      "words_offset": 295
    },
    {
      "index": 28,
      "text": "Travelers reports significantly elevated engineering excellence.",
      "checksum": "sha256:885d6fd552331742468f1cbada53ff8c3091b5790bff510fa733929b6448133f",
      "wav": "chunk-28.wav",
      "duration": 3.8080725623582765,
      "word_count": 6,
      "words_offset": 308
    },
    {
      "index": 29,
      "text": "And 100 percent of Walleye Capital uses Claude Code.",
      "checksum": "sha256:12abda12db6fcca8a6e05ed81718e1b01876430447c30dbb51e95c70f982c196",
      "wav": "chunk-29.wav",
      "duration": 2.8792743764172335,
      "word_count": 9,
      "words_offset": 314
    },
    {
      "index": 30,
      "text": "Their entire 400-person hedge fund. Every single employee.",
      "checksum": "sha256:d12540a0802a07e3978310af62c845d154f6462dd312cd9cacb05496d6a47bba",
      "wav": "chunk-30.wav",
      "duration": 3.5294331065759637,
      "word_count": 8,
      "words_offset": 323
    },
    {
      "index": 31,
      "text": "Read the full announcement at anthropic dot com slash news slash finance agents.",
      "checksum": "sha256:75abbda355adbc9aee00d7065527b6dbc75cfe2f1af66a2deef566cfd60aa501",
      "wav": "chunk-31.wav",
      "duration": 4.783310657596372,
      "word_count": 13,
      "words_offset": 331
    },
    {
      "index": 32,
      "text": "If you want to learn more about AI, check out the dynamous dot ai community.",
      "checksum": "sha256:0566490f0edfe75e3ccfcd526b9adffe78832ea45c8a4e4110da0244a22b4f11",
      "wav": "chunk-32.wav",
      "duration": 4.133151927437642,
      "word_count": 15,
      "words_offset": 344
    }
