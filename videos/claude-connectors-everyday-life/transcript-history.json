  "chunks": [
    {
      "index": 0,
      "text": "Claude just got fifteen new connectors. AllTrails.",
      "checksum": "sha256:3cb7e9b8ad4ce4e291e47c862b56d6c894340a117eb8669c902368cb50f9112b",
      "wav": "chunk-00.wav",
      "duration": 2.8792743764172335,
      "word_count": 7,
      "words_offset": 0
    },
    {
      "index": 1,
      "text": "Spotify. Uber. Living inside the conversation.",
      "checksum": "sha256:75fbbf8caa3a4642870d27917b1ab7d0f39fbc62be7ef6000969bea1afb79e2e",
      "wav": "chunk-01.wav",
      "duration": 3.01859410430839,
      "word_count": 6,
      "words_offset": 7
    },
    {
      "index": 2,
      "text": "Ask for a weekend hike. AllTrails opens with options, right there in the chat.",
      "checksum": "sha256:9d4ceb903bd0959d3fc185c54b72a048947dd9eba35f5985b146f1c0f26f53bf",
      "wav": "chunk-02.wav",
      "duration": 4.551111111111111,
      "word_count": 14,
      "words_offset": 13
    },
    {
      "index": 3,
      "text": "Refine the trail length. Pick a difficulty.",
      "checksum": "sha256:903a0956ab04919af3727b6a0df96e2556422da14fa43e38d317d81c045dedec",
      "wav": "chunk-03.wav",
      "duration": 2.414875283446712,
      "word_count": 7,
      "words_offset": 27
    },
    {
      "index": 4,
      "text": "Browse photos. No tabs. No copy paste. The directory crossed two hundred connectors.",
      "checksum": "sha256:7193475eab07a73b97dbcd9ac3d0032c7f07bb23b56b59fbbc5a9c029aeb4dc1",
      "wav": "chunk-04.wav",
      "duration": 5.294149659863946,
      "word_count": 13,
      "words_offset": 34
    },
    {
      "index": 5,
      "text": "From work tools into everyday life. Power users chain them.",
      "checksum": "sha256:48dcb11d3e5e7c47f85f19d3969411dd99f4505316bca4390bdb5c9b3fb49563",
      "wav": "chunk-05.wav",
      "duration": 3.5294331065759637,
      "word_count": 10,
      "words_offset": 47
    },
    {
      "index": 6,
      "text": "Pull a query from Amplitude. Turn it into a Canva deck.",
      "checksum": "sha256:ad9415bb2d11980754e9a8376df799ff78cdddfc0ccf09f87fa404fb27d664cd",
      "wav": "chunk-06.wav",
      "duration": 3.2043537414965986,
      "word_count": 11,
      "words_offset": 57
    },
    {
      "index": 7,
      "text": "Drop the link into Asana. One conversation.",
      "checksum": "sha256:ecd8b8c26fc5507f3b8366956246beb69306d6fcf4c5f348cc1bac5ea5e15159",
      "wav": "chunk-07.wav",
      "duration": 2.5541950113378684,
      "word_count": 7,
      "words_offset": 68
    },
    {
      "index": 8,
      "text": "Five tools. Zero tabs. Claude always asks before it buys or books.",
      "checksum": "sha256:9c59b8a9bcafad4c5a0237236ee28a34c957ab187b8ef77df9a7562ad0a7d9ac",
      "wav": "chunk-08.wav",
      "duration": 4.551111111111111,
      "word_count": 12,
      "words_offset": 75
    },
    {
      "index": 9,
      "text": "Your data stays siloed across apps. Anyone can submit a connector to the directory now.",
      "checksum": "sha256:8f2b2b74f0fb43c16adb58b9b429b213d74e866e06a198136635be74a543fcaf",
      "wav": "chunk-09.wav",
      "duration": 4.876190476190477,
      "word_count": 15,
      "words_offset": 87
    },
    {
      "index": 10,
      "text": "The browser tab era is ending. AI living inside every app, useful or creepy?",
      "checksum": "sha256:2fb9b5735641e82de9d86aac144eb915fba2097a76d364a6a4433c85486b4361",
      "wav": "chunk-10.wav",
      "duration": 5.201269841269841,
      "word_count": 14,
      "words_offset": 102
    },
    {
      "index": 11,
      "text": "Drop your pick below.",
