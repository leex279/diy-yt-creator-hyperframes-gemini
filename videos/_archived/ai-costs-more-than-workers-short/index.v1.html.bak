<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>AI Costs MORE Than The Worker It Replaced</title>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body {
    width: 1080px;
    height: 1920px;
    overflow: hidden;
    background: #0B0F18;
    font-family: 'Inter', system-ui, sans-serif;
    color: #F5F1EB;
    -webkit-font-smoothing: antialiased;
  }

  #root {
    --bg: #0B0F18;
    --card: #161B26;
    --text: #F5F1EB;
    --text-dim: #9A958D;
    --orange: #E97458;
    --purple: #A78BFA;
    --blue:   #6B9AEF;
    --green:  #7DD3A6;
    --red:    #D14343;
    --pill-bg: rgba(245, 241, 235, 0.08);
    --pill-border: rgba(245, 241, 235, 0.18);
    --pad-top: 240px;
    --pad-x: 60px;
    --pad-bottom: 240px;
    --mono: 'JetBrains Mono', ui-monospace, monospace;
    --sans: 'Inter', system-ui, sans-serif;
  }

  #ambient {
    position: absolute;
    inset: -200px;
    background:
      radial-gradient(circle at 30% 25%, rgba(233,116,88,0.10), transparent 60%),
      radial-gradient(circle at 75% 80%, rgba(167,139,250,0.06), transparent 55%);
    pointer-events: none;
    z-index: 0;
  }
  #shape-backdrop {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  #shape-backdrop img {
    position: absolute;
    opacity: 0.055;
    object-fit: contain;
    pointer-events: none;
    filter: grayscale(1) brightness(2.2);
  }
  #noise-overlay {
    position: absolute;
    inset: 0;
    width: 1080px;
    height: 1920px;
    pointer-events: none;
    z-index: 11;
    opacity: 0.035;
    mix-blend-mode: overlay;
  }

  #top-banner {
    position: absolute;
    top: 70px;
    left: 0;
    width: 1080px;
    z-index: 10;
    pointer-events: none;
    text-align: center;
  }
  #top-banner-overline {
    display: inline-block;
    font-family: var(--mono);
    font-weight: 800;
    font-size: 58px;
    letter-spacing: 14px;
    color: var(--text);
    text-transform: uppercase;
    padding: 18px 47px;
    border-radius: 999px;
    background: rgba(245, 241, 235, 0.06);
    border: 2.5px solid rgba(245, 241, 235, 0.22);
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
  }
  #top-banner-overline .accent {
    color: var(--orange);
  }

  #progress-track {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 1080px;
    height: 6px;
    background: rgba(245, 241, 235, 0.08);
    z-index: 10;
  }
  #progress-fill {
    width: 0;
    height: 100%;
    background: var(--orange);
    box-shadow: 0 0 12px rgba(233, 116, 88, 0.6);
  }

  .phase {
    position: absolute;
    top: 0;
    left: 0;
    width: 1080px;
    height: 1920px;
    overflow: hidden;
  }
  #phase1 { z-index: 1; opacity: 1; }
  #phase2 { z-index: 2; opacity: 0; }
  #phase3 { z-index: 3; opacity: 0; }
  #phase4 { z-index: 4; opacity: 0; }
  #phase5 { z-index: 5; opacity: 0; }
  #phase6 { z-index: 6; opacity: 0; }
  #phase7 { z-index: 7; opacity: 0; }
  #phase8 { z-index: 8; opacity: 0; }
  #phase9 { z-index: 9; opacity: 0; }

  .phase-content {
    width: 100%;
    height: 100%;
    padding: var(--pad-top) var(--pad-x) var(--pad-bottom);
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  .overline {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 36px;
    letter-spacing: 6px;
    text-transform: uppercase;
  }

  /* PHASE 1 — Thumbnail open — $113K invoice */
  #p1-topic-lockup {
    position: absolute;
    top: 0;
    left: 0;
    width: 1080px;
    height: 1920px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--pad-top) var(--pad-x) var(--pad-bottom);
    gap: 36px;
    pointer-events: none;
    z-index: 2;
  }
  #p1-overline { color: var(--orange); }
  #p1-invoice-card {
    width: 940px;
    padding: 48px 40px;
    border-radius: 28px;
    background: linear-gradient(135deg, rgba(233,116,88,0.22), rgba(233,116,88,0.06));
    border: 2px solid rgba(233,116,88,0.50);
    box-shadow: 0 18px 48px rgba(233,116,88,0.22);
    display: flex;
    flex-direction: column;
    gap: 18px;
    align-items: center;
    text-align: center;
  }
  #p1-invoice-label {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 34px;
    letter-spacing: 4px;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  #p1-counter {
    font-family: var(--sans);
    font-weight: 900;
    font-size: 168px;
    line-height: 0.9;
    letter-spacing: -5px;
    color: var(--orange);
    text-shadow: 0 0 80px rgba(233,116,88,0.55);
    font-variant-numeric: tabular-nums lining-nums;
  }
  #p1-counter-sub {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 40px;
    letter-spacing: 3px;
    color: var(--text);
  }
  #p1-receipt-line {
    font-family: var(--mono);
    font-weight: 600;
    font-size: 38px;
    letter-spacing: 2px;
    color: var(--text-dim);
    margin-top: 6px;
  }

  /* PHASE 2 — NVIDIA quote */
  #phase2 .phase-content {
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 36px;
  }
  #p2-nvidia-mark {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    padding: 18px 36px;
    border-radius: 16px;
    background: rgba(118, 185, 0, 0.12);
    border: 2px solid rgba(118, 185, 0, 0.40);
  }
  #p2-nvidia-mark .dot {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #76B900;
    box-shadow: 0 0 24px rgba(118,185,0,0.6);
  }
  #p2-nvidia-mark .name {
    font-family: var(--sans);
    font-weight: 900;
    font-size: 42px;
    letter-spacing: 4px;
    color: var(--text);
  }
  #p2-quote {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 76px;
    line-height: 1.15;
    color: var(--text);
    max-width: 960px;
    margin-top: 24px;
  }
  #p2-quote .farbeyond {
    position: relative;
    display: inline-block;
    color: var(--orange);
  }
  #p2-mark {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -8px;
    height: 14px;
    background: var(--orange);
    border-radius: 999px;
    transform-origin: left center;
    transform: scaleX(0);
    opacity: 0.7;
  }
  #p2-attrib {
    font-family: var(--mono);
    font-weight: 600;
    font-size: 32px;
    letter-spacing: 2px;
    color: var(--text-dim);
    margin-top: 24px;
  }

  /* PHASE 3 — Uber budget gone */
  #phase3 .phase-content {
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    gap: 30px;
  }
  #p3-overline {
    color: var(--text);
    background: rgba(0,0,0,0.7);
    padding: 12px 28px;
    border-radius: 10px;
    border: 2px solid rgba(245, 241, 235, 0.4);
  }
  #p3-headline {
    font-family: var(--sans);
    font-weight: 800;
    font-size: 64px;
    line-height: 1.05;
    color: var(--text);
    max-width: 960px;
    letter-spacing: -1px;
  }
  #p3-budget-frame {
    position: relative;
    width: 940px;
    margin-top: 12px;
  }
  #p3-budget-label {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 34px;
    letter-spacing: 2px;
    color: var(--text-dim);
    text-align: left;
    margin-bottom: 12px;
  }
  #p3-budget-track {
    width: 940px;
    height: 96px;
    background: rgba(245,241,235,0.08);
    border: 2px solid rgba(245,241,235,0.18);
    border-radius: 18px;
    overflow: hidden;
    position: relative;
  }
  #p3-budget-fill {
    width: 0%;
    height: 100%;
    background: linear-gradient(90deg, var(--orange), var(--red));
    box-shadow: 0 0 32px rgba(233,116,88,0.5);
  }
  #p3-budget-slam {
    margin-top: 28px;
    font-family: var(--sans);
    font-weight: 900;
    font-size: 118px;
    line-height: 0.95;
    letter-spacing: -3px;
    color: var(--red);
    text-shadow: 0 0 40px rgba(209,67,67,0.5);
    opacity: 0;
  }
  #p3-receipts {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 16px;
    width: 940px;
  }
  .p3-receipt-row {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 44px;
    letter-spacing: 1px;
    color: var(--text);
    padding: 18px 26px;
    border-radius: 14px;
    background: rgba(245,241,235,0.06);
    border: 1.5px solid rgba(245,241,235,0.16);
    text-align: left;
    opacity: 0;
  }
  .p3-receipt-row .num {
    color: var(--orange);
    font-weight: 900;
  }

  /* PHASE 4 — Trajectory 3-bar */
  #phase4 .phase-content {
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    gap: 26px;
  }
  #p4-overline { color: var(--orange); }
  #p4-headline {
    font-family: var(--sans);
    font-weight: 800;
    font-size: 60px;
    line-height: 1.05;
    color: var(--text);
    max-width: 940px;
    letter-spacing: -1px;
  }
  #p4-chart {
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    justify-content: center;
    gap: 38px;
    width: 940px;
    height: 720px;
    margin-top: 24px;
    padding-bottom: 64px;
    border-bottom: 4px solid rgba(245,241,235,0.18);
    position: relative;
  }
  .p4-bar-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    width: 200px;
  }
  .p4-bar-num {
    font-family: var(--sans);
    font-weight: 900;
    font-size: 56px;
    line-height: 0.9;
    letter-spacing: -2px;
    opacity: 0;
    font-variant-numeric: tabular-nums lining-nums;
  }
  .p4-bar {
    width: 200px;
    border-radius: 14px 14px 0 0;
    height: 0;
  }
  .p4-bar.b1 {
    background: linear-gradient(180deg, rgba(167,139,250,0.65), rgba(167,139,250,0.3));
    border: 2px solid rgba(167,139,250,0.7);
    box-shadow: 0 -6px 28px rgba(167,139,250,0.3);
  }
  .p4-bar-col:nth-child(1) .p4-bar-num { color: var(--purple); }
  .p4-bar.b2 {
    background: linear-gradient(180deg, rgba(107,154,239,0.65), rgba(107,154,239,0.3));
    border: 2px solid rgba(107,154,239,0.7);
    box-shadow: 0 -6px 28px rgba(107,154,239,0.3);
  }
  .p4-bar-col:nth-child(2) .p4-bar-num { color: var(--blue); }
  .p4-bar.b3 {
    background: linear-gradient(180deg, rgba(233,116,88,0.75), rgba(233,116,88,0.4));
    border: 2px solid rgba(233,116,88,0.85);
    box-shadow: 0 -6px 36px rgba(233,116,88,0.5);
  }
  .p4-bar-col:nth-child(3) .p4-bar-num { color: var(--orange); }
  .p4-bar-month {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 32px;
    letter-spacing: 2px;
    color: var(--text-dim);
    position: absolute;
    bottom: 16px;
  }
  .p4-bar-col:nth-child(1) .p4-bar-month { left: 90px; }
  .p4-bar-col:nth-child(2) .p4-bar-month { left: 366px; }
  .p4-bar-col:nth-child(3) .p4-bar-month { left: 642px; }
  #p4-caption {
    font-family: var(--mono);
    font-weight: 600;
    font-size: 32px;
    letter-spacing: 2px;
    color: var(--text-dim);
    margin-top: 8px;
  }

  /* PHASE 5 — $28K / PERSON */
  #phase5 .phase-content {
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 32px;
  }
  #p5-overline { color: var(--orange); }
  #p5-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 920px;
    padding: 56px 36px;
    border-radius: 28px;
    background: linear-gradient(135deg, rgba(233,116,88,0.22), rgba(233,116,88,0.06));
    border: 2.5px solid rgba(233,116,88,0.55);
    box-shadow: 0 18px 48px rgba(233,116,88,0.25);
  }
  #p5-num {
    font-family: var(--sans);
    font-weight: 900;
    font-size: 220px;
    line-height: 0.85;
    letter-spacing: -6px;
    color: var(--orange);
    text-shadow: 0 0 80px rgba(233,116,88,0.55);
  }
  #p5-label {
    margin-top: 18px;
    font-family: var(--mono);
    font-weight: 800;
    font-size: 44px;
    letter-spacing: 4px;
    color: var(--text);
  }
  #p5-sub {
    margin-top: 28px;
    font-family: var(--sans);
    font-weight: 700;
    font-size: 44px;
    line-height: 1.15;
    color: var(--text-dim);
    max-width: 920px;
  }

  /* PHASE 6 — Gartner 40% + 92K layoffs */
  #phase6 .phase-content {
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    gap: 28px;
  }
  #p6-overline { color: var(--purple); }
  #p6-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 920px;
    padding: 44px 32px;
    border-radius: 28px;
    background: linear-gradient(135deg, rgba(167,139,250,0.22), rgba(167,139,250,0.06));
    border: 2.5px solid rgba(167,139,250,0.55);
    box-shadow: 0 18px 48px rgba(167,139,250,0.25);
  }
  #p6-num {
    font-family: var(--sans);
    font-weight: 900;
    font-size: 200px;
    line-height: 0.88;
    letter-spacing: -5px;
    color: var(--purple);
    text-shadow: 0 0 80px rgba(167,139,250,0.5);
  }
  #p6-label {
    margin-top: 16px;
    font-family: var(--mono);
    font-weight: 800;
    font-size: 36px;
    letter-spacing: 3px;
    color: var(--text);
    line-height: 1.25;
  }
  #p6-sub {
    margin-top: 6px;
    font-family: var(--mono);
    font-weight: 600;
    font-size: 32px;
    letter-spacing: 2px;
    color: var(--text-dim);
  }
  #p6-layoffs {
    margin-top: 28px;
    width: 920px;
    padding: 28px 32px;
    border-radius: 22px;
    background: linear-gradient(135deg, rgba(209,67,67,0.20), rgba(209,67,67,0.05));
    border: 2px solid rgba(209,67,67,0.45);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
  }
  #p6-layoffs-num {
    font-family: var(--sans);
    font-weight: 900;
    font-size: 140px;
    line-height: 0.9;
    letter-spacing: -4px;
    color: var(--red);
    font-variant-numeric: tabular-nums lining-nums;
  }
  #p6-layoffs-label {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 32px;
    letter-spacing: 3px;
    color: var(--text);
  }

  /* PHASE 7 — Inference cost down */
  #phase7 .phase-content {
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    gap: 30px;
  }
  #p7-overline { color: var(--green); }
  #p7-headline {
    font-family: var(--sans);
    font-weight: 800;
    font-size: 64px;
    line-height: 1.08;
    color: var(--text);
    max-width: 960px;
    letter-spacing: -1px;
  }
  #p7-headline .accent { color: var(--green); }
  #p7-chart {
    position: relative;
    width: 940px;
    height: 560px;
    margin-top: 16px;
  }
  #p7-svg {
    position: absolute;
    left: 0;
    top: 0;
    width: 940px;
    height: 540px;
    overflow: visible;
  }
  .p7-label {
    position: absolute;
    width: 200px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    opacity: 0;
  }
  .p7-label .val {
    font-family: var(--sans);
    font-weight: 900;
    font-size: 56px;
    color: var(--green);
    letter-spacing: -1px;
    line-height: 0.95;
  }
  .p7-label .yr {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 32px;
    letter-spacing: 2px;
    color: var(--text-dim);
  }
  #p7-label-1 {
    left: 134px;
    top: 36px;
    align-items: flex-start;
    text-align: left;
  }
  #p7-label-2 {
    left: 370px;
    top: 400px;
    align-items: center;
    text-align: center;
  }
  #p7-label-3 {
    left: 596px;
    top: 372px;
    align-items: flex-end;
    text-align: right;
  }
  #p7-caption {
    font-family: var(--mono);
    font-weight: 600;
    font-size: 34px;
    letter-spacing: 2px;
    color: var(--text-dim);
    margin-top: 8px;
  }

  /* PHASE 8 — MIT 95% */
  #phase8 .phase-content {
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 36px;
  }
  #p8-overline { color: var(--orange); }
  #p8-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 920px;
    min-height: 520px;
    padding: 48px 32px;
    border-radius: 28px;
    background: linear-gradient(135deg, rgba(233,116,88,0.22), rgba(233,116,88,0.06));
    border: 2.5px solid rgba(233,116,88,0.55);
    box-shadow: 0 18px 48px rgba(233,116,88,0.25);
  }
  #p8-num {
    font-family: var(--sans);
    font-weight: 900;
    font-size: 240px;
    line-height: 1.0;
    letter-spacing: -7px;
    color: var(--orange);
    text-shadow: 0 0 80px rgba(233,116,88,0.55);
  }
  #p8-label {
    margin-top: 16px;
    font-family: var(--mono);
    font-weight: 800;
    font-size: 42px;
    letter-spacing: 3px;
    color: var(--text);
    line-height: 1.25;
  }
  #p8-sub {
    margin-top: 18px;
    font-family: var(--mono);
    font-weight: 600;
    font-size: 34px;
    letter-spacing: 2px;
    color: var(--text-dim);
  }

  /* PHASE 9 — Thumbnail close */
  #phase9 .phase-content {
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 32px;
  }
  #p9-brand-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
  }
  #p9-brand-anth {
    height: 50px;
    width: auto;
    opacity: 0.8;
  }
  #p9-brand-nvidia {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 12px 22px;
    border-radius: 12px;
    background: rgba(118, 185, 0, 0.12);
    border: 2px solid rgba(118, 185, 0, 0.40);
  }
  #p9-brand-nvidia .dot {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #76B900;
  }
  #p9-brand-nvidia .name {
    font-family: var(--sans);
    font-weight: 900;
    font-size: 32px;
    letter-spacing: 3px;
    color: var(--text);
  }
  #p9-slam {
    font-family: var(--sans);
    font-weight: 900;
    font-size: 118px;
    line-height: 0.92;
    letter-spacing: -3px;
    color: var(--text);
    text-shadow: 0 6px 24px rgba(0,0,0,0.6);
    max-width: 1060px;
  }
  #p9-slam .b1 { color: var(--orange); }
  #p9-slam .b2 { color: var(--green); }
  #p9-receipts {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 36px;
    letter-spacing: 2px;
    color: var(--text-dim);
    line-height: 1.4;
  }
  #p9-receipts .accent { color: var(--text); }
  /* MANDATORY: engagement CTA per .claude/rules/engagement-cta.md */
  #cta-question {
    font-family: var(--sans);
    font-weight: 800;
    font-size: 52px;
    line-height: 1.18;
    letter-spacing: -1px;
    color: var(--orange);
    text-align: center;
    max-width: 940px;
    margin-top: 16px;
    padding: 22px 28px;
    border-radius: 24px;
    background: linear-gradient(135deg, rgba(233,116,88,0.15), rgba(233,116,88,0.03));
    border: 2px solid rgba(233,116,88,0.40);
  }
  #cta-question .em {
    color: var(--text);
    font-style: italic;
  }
  #p9-cta-pill {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 20px 40px;
    border-radius: 999px;
    background: var(--pill-bg);
    border: 1.5px solid var(--pill-border);
    font-family: var(--sans);
    font-weight: 700;
    font-size: 46px;
    color: var(--text);
    letter-spacing: 0.5px;
    margin-top: 8px;
  }
  #p9-cta-pill .arrow {
    color: var(--orange);
    font-size: 54px;
    line-height: 0.7;
  }
</style>
</head>
<body>
<div id="root"
     data-composition-id="main"
     data-start="0"
     data-duration="112"
     data-width="1080"
     data-height="1920">

  <div id="ambient"></div>
  <div id="shape-backdrop"></div>

  <div id="top-banner">
    <div id="top-banner-overline">AI ECONOMICS <span class="accent">·</span> 2026</div>
  </div>

  <div id="progress-track"><div id="progress-fill"></div></div>

  <!-- PHASE 1 — Thumbnail open (0–12s) -->
  <div id="phase1" class="phase">
    <div id="p1-topic-lockup">
      <div class="overline" id="p1-overline">Anthropic invoice · April 2026</div>
      <div id="p1-invoice-card">
        <div id="p1-invoice-label">Total due</div>
        <div id="p1-counter">$113,421</div>
        <div id="p1-counter-sub">/ MONTH</div>
      </div>
      <div id="p1-receipt-line">SWAN AI · 4 EMPLOYEES · 1 INVOICE</div>
    </div>
  </div>

  <!-- PHASE 2 — NVIDIA quote (12–24s) -->
  <div id="phase2" class="phase">
    <div class="phase-content">
      <div id="p2-nvidia-mark">
        <div class="dot"></div>
        <div class="name">NVIDIA</div>
      </div>
      <div id="p2-quote">
        "The cost of compute is
        <span class="farbeyond">far beyond<span id="p2-mark"></span></span>
        the costs of the employees."
      </div>
      <div id="p2-attrib">Bryan Catanzaro · VP, Applied Deep Learning</div>
    </div>
  </div>

  <!-- PHASE 3 — Uber budget gone (24–36s) -->
  <div id="phase3" class="phase">
    <div class="phase-content">
      <div class="overline" id="p3-overline">UBER · 2026 AI BUDGET</div>
      <div id="p3-headline">Full-year budget. Gone by April.</div>
      <div id="p3-budget-frame">
        <div id="p3-budget-label">USED &gt; 100% by April 2026</div>
        <div id="p3-budget-track"><div id="p3-budget-fill"></div></div>
      </div>
      <div id="p3-budget-slam">GONE BY APRIL.</div>
      <div id="p3-receipts">
        <div class="p3-receipt-row" id="p3-r1"><span class="num">84%</span> of Uber devs use agentic coding</div>
        <div class="p3-receipt-row" id="p3-r2"><span class="num">11%</span> of backend code is AI-written</div>
        <div class="p3-receipt-row" id="p3-r3"><span class="num">6&times;</span> AI cost growth since 2024</div>
      </div>
    </div>
  </div>

  <!-- PHASE 4 — Trajectory 3-bar (36–50s) -->
  <div id="phase4" class="phase">
    <div class="phase-content">
      <div class="overline" id="p4-overline">Swan AI &middot; Anthropic invoice</div>
      <div id="p4-headline">Roughly doubling every month.</div>
      <div id="p4-chart">
        <div class="p4-bar-col">
          <div class="p4-bar-num" id="p4-num-1">$28K</div>
          <div class="p4-bar b1" id="p4-bar-1"></div>
          <div class="p4-bar-month">FEB</div>
        </div>
        <div class="p4-bar-col">
          <div class="p4-bar-num" id="p4-num-2">$51K</div>
          <div class="p4-bar b2" id="p4-bar-2"></div>
          <div class="p4-bar-month">MAR</div>
        </div>
        <div class="p4-bar-col">
          <div class="p4-bar-num" id="p4-num-3">$113K</div>
          <div class="p4-bar b3" id="p4-bar-3"></div>
          <div class="p4-bar-month">APR</div>
        </div>
      </div>
      <div id="p4-caption">FEB &rarr; MAR &rarr; APR &middot; 2&times; MoM</div>
    </div>
  </div>

  <!-- PHASE 5 — $28K / PERSON (50–60s) -->
  <div id="phase5" class="phase">
    <div class="phase-content">
      <div class="overline" id="p5-overline">The math</div>
      <div id="p5-pill">
        <div id="p5-num">$28K</div>
        <div id="p5-label">PER PERSON &middot; PER MONTH</div>
      </div>
      <div id="p5-sub">Swan AI &middot; 4 employees on Anthropic tokens.</div>
    </div>
  </div>

  <!-- PHASE 6 — Gartner 40% + 92K layoffs (60–72s) -->
  <div id="phase6" class="phase">
    <div class="phase-content">
      <div class="overline" id="p6-overline">Gartner forecast</div>
      <div id="p6-pill">
        <div id="p6-num">40%</div>
        <div id="p6-label">OF AGENTIC AI PROJECTS<br>KILLED BY 2027</div>
        <div id="p6-sub">3,400-org poll &middot; 2025-06-25</div>
      </div>
      <div id="p6-layoffs">
        <div id="p6-layoffs-num">92,000</div>
        <div id="p6-layoffs-label">TECH LAYOFFS &middot; 2026 (and counting)</div>
      </div>
    </div>
  </div>

  <!-- PHASE 7 — Inference cost down (72–86s) -->
  <div id="phase7" class="phase">
    <div class="phase-content">
      <div class="overline" id="p7-overline">The counter case</div>
      <div id="p7-headline">BUT inference cost drops <span class="accent">10&times; / year.</span></div>
      <div id="p7-chart">
        <svg id="p7-svg" viewBox="0 0 940 540" preserveAspectRatio="none">
          <line x1="0" y1="0" x2="0" y2="540" stroke="rgba(245,241,235,0.18)" stroke-width="3" />
          <line x1="0" y1="540" x2="940" y2="540" stroke="rgba(245,241,235,0.18)" stroke-width="3" />
          <polyline id="p7-polyline"
                    points="100,80 470,360 840,480"
                    stroke="#7DD3A6" stroke-width="8"
                    stroke-linecap="round" stroke-linejoin="round"
                    fill="none"
                    stroke-dasharray="1000" stroke-dashoffset="1000"
                    filter="drop-shadow(0 0 16px rgba(125,211,166,0.55))" />
          <circle id="p7-dot-1" cx="100" cy="80"  r="18" fill="#7DD3A6" opacity="0"
                  filter="drop-shadow(0 0 14px rgba(125,211,166,0.85))" />
          <circle id="p7-dot-2" cx="470" cy="360" r="18" fill="#7DD3A6" opacity="0"
                  filter="drop-shadow(0 0 14px rgba(125,211,166,0.85))" />
          <circle id="p7-dot-3" cx="840" cy="480" r="22" fill="#7DD3A6" opacity="0"
                  filter="drop-shadow(0 0 18px rgba(125,211,166,0.95))" />
        </svg>
        <div class="p7-label" id="p7-label-1">
          <div class="val">$60</div>
          <div class="yr">2021 &middot; /Mtok</div>
        </div>
        <div class="p7-label" id="p7-label-2">
          <div class="val">$0.06</div>
          <div class="yr">TODAY</div>
        </div>
        <div class="p7-label" id="p7-label-3">
          <div class="val">$0.006</div>
          <div class="yr">2030 (proj.)</div>
        </div>
      </div>
      <div id="p7-caption">a16z LLMflation &middot; ~90% drop projected by 2030</div>
    </div>
  </div>

  <!-- PHASE 8 — MIT 95% pilots return zero (86–98s) -->
  <div id="phase8" class="phase">
    <div class="phase-content">
      <div class="overline" id="p8-overline">MIT &middot; enterprise GenAI</div>
      <div id="p8-pill">
        <div id="p8-num">95%</div>
        <div id="p8-label">OF CORPORATE GENAI PILOTS<br>RETURN ZERO</div>
        <div id="p8-sub">on $30&ndash;40B in enterprise spend</div>
      </div>
    </div>
  </div>

  <!-- PHASE 9 — Thumbnail close (98–112s) -->
  <div id="phase9" class="phase">
    <div class="phase-content">
      <div id="p9-brand-row">
        <img id="p9-brand-anth" src="assets/anthropic-logo-light.svg" alt="Anthropic" />
        <div id="p9-brand-nvidia">
          <div class="dot"></div>
          <div class="name">NVIDIA</div>
        </div>
      </div>
      <div id="p9-slam"><span class="b1">BUBBLE</span><br>OR<br><span class="b2">BREAKTHROUGH?</span></div>
      <div id="p9-receipts">
        <span class="accent">92K layoffs.</span> <span class="accent">$113K invoices.</span><br><span class="accent">95% pilots fail.</span>
      </div>
      <div id="cta-question">AI bills &gt; payroll. <span class="em">Bubble pop or short-term mismatch?</span></div>
      <div id="p9-cta-pill">Drop your pick<span class="arrow">&rarr;</span></div>
    </div>
  </div>

  <!-- Narration -->
  <audio id="narration"
         class="clip"
         src="audio/narration.wav"
         data-start="0"
         data-duration="110.7"
         data-track-index="2"
         data-volume="1"></audio>

  <!-- Phase-transition whooshes -->
  <audio id="sfx-w1" class="clip" src="assets/sfx/cinematic-whoosh.mp3" data-start="12" data-duration="1.5" data-track-index="3" data-volume="0.11"></audio>
  <audio id="sfx-w2" class="clip" src="assets/sfx/cinematic-whoosh.mp3" data-start="24" data-duration="1.5" data-track-index="3" data-volume="0.11"></audio>
  <audio id="sfx-w3" class="clip" src="assets/sfx/cinematic-whoosh.mp3" data-start="36" data-duration="1.5" data-track-index="3" data-volume="0.11"></audio>
  <audio id="sfx-w4" class="clip" src="assets/sfx/cinematic-whoosh.mp3" data-start="50" data-duration="1.5" data-track-index="3" data-volume="0.11"></audio>
  <audio id="sfx-w5" class="clip" src="assets/sfx/cinematic-whoosh.mp3" data-start="60" data-duration="1.5" data-track-index="3" data-volume="0.11"></audio>
  <audio id="sfx-w6" class="clip" src="assets/sfx/cinematic-whoosh.mp3" data-start="72" data-duration="1.5" data-track-index="3" data-volume="0.11"></audio>
  <audio id="sfx-w7" class="clip" src="assets/sfx/cinematic-whoosh.mp3" data-start="86" data-duration="1.5" data-track-index="3" data-volume="0.11"></audio>
  <audio id="sfx-w8" class="clip" src="assets/sfx/cinematic-whoosh.mp3" data-start="98" data-duration="1.5" data-track-index="3" data-volume="0.11"></audio>

  <!-- Film-grain overlay -->
  <svg id="noise-overlay" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <filter id="noise-filter" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence type="fractalNoise" baseFrequency="0.7" numOctaves="4" seed="42" stitchTiles="stitch" result="noise" />
        <feColorMatrix type="saturate" values="0" in="noise" result="monoNoise" />
      </filter>
    </defs>
    <rect width="100%" height="100%" filter="url(#noise-filter)" fill="white" />
  </svg>
</div>

<script>
  function seedHash(seed) {
    let h = 1779033703 ^ seed.length;
    for (let i = 0; i < seed.length; i++) {
      h = Math.imul(h ^ seed.charCodeAt(i), 3432918353);
      h = (h << 13) | (h >>> 19);
    }
    h = Math.imul(h ^ (h >>> 16), 2246822507);
    h = Math.imul(h ^ (h >>> 13), 3266489909);
    h ^= h >>> 16;
    return (h >>> 0) / 4294967296;
  }
  function spawnShapes(seedPrefix, container) {
    const shapes = [
      'assets/shapes/shape1.svg',
      'assets/shapes/shape2.svg',
      'assets/shapes/shape3.svg',
      'assets/shapes/shape4.svg',
      'assets/shapes/logo-anthropic.png',
      'assets/shapes/logo-nvidia.png',
      'assets/shapes/logo-openai.png',
      'assets/shapes/logo-google.png',
      'assets/shapes/logo-microsoft.png'
    ];
    const count = 14, w = 1080, h = 1920, minSize = 180, sizeRange = 200;
    const minDist = 340, MAX_TRIES = 80;
    const placed = [];
    let attempt = 0;
    for (let i = 0; i < count; i++) {
      let best = null, bestScore = -1;
      for (let t = 0; t < MAX_TRIES; t++) {
        const seed = seedPrefix + '-' + i + '-' + attempt++;
        const size = minSize + seedHash(seed + '-size') * sizeRange;
        const cx = seedHash(seed + '-x') * (w - size * 0.4) + size * 0.2;
        const cy = seedHash(seed + '-y') * (h - size * 0.4) + size * 0.2;
        const rot = (seedHash(seed + '-rot') - 0.5) * 90;
        let nearest = Infinity;
        for (const p of placed) {
          const dx = cx - p.cx, dy = cy - p.cy;
          const d2 = dx * dx + dy * dy;
          if (d2 < nearest) nearest = d2;
        }
        if (nearest >= minDist * minDist) { best = { cx, cy, size, rot }; break; }
        if (nearest > bestScore) { bestScore = nearest; best = { cx, cy, size, rot }; }
      }
      placed.push(best);
      const img = document.createElement('img');
      img.src = shapes[i % shapes.length];
      img.style.cssText =
        'left:' + (best.cx - best.size / 2) + 'px;' +
        'top:' + (best.cy - best.size / 2) + 'px;' +
        'width:' + best.size + 'px;' +
        'height:' + best.size + 'px;';
      container.appendChild(img);
      gsap.set(img, { rotation: best.rot });
    }
  }
  function repositionShapesPerPhase(tl, container, seedPrefix, phaseStartTimes) {
    const imgs = Array.from(container.querySelectorAll('img'));
    if (!imgs.length || !phaseStartTimes.length) return;
    const w = 1080, h = 1920, minDist = 340, MAX_TRIES = 80;
    const anchors = imgs.map(img => ({
      left: parseFloat(img.style.left),
      top:  parseFloat(img.style.top),
      size: parseFloat(img.style.width),
    }));
    phaseStartTimes.forEach((sceneT, sceneIdx) => {
      const placed = [];
      let attempt = 0;
      const positions = imgs.map((img, i) => {
        const size = anchors[i].size;
        let best = null, bestScore = -1;
        for (let t = 0; t < MAX_TRIES; t++) {
          const seed = seedPrefix + '-phase' + sceneIdx + '-' + i + '-' + (attempt++);
          const cx = seedHash(seed + '-x') * (w - size * 0.4) + size * 0.2;
          const cy = seedHash(seed + '-y') * (h - size * 0.4) + size * 0.2;
          const rot = (seedHash(seed + '-rot') - 0.5) * 90;
          let nearest = Infinity;
          for (const p of placed) {
            const dx = cx - p.cx, dy = cy - p.cy;
            const d2 = dx * dx + dy * dy;
            if (d2 < nearest) nearest = d2;
          }
          if (nearest >= minDist * minDist) { best = { cx, cy, rot }; break; }
          if (nearest > bestScore) { bestScore = nearest; best = { cx, cy, rot }; }
        }
        placed.push({ cx: best.cx, cy: best.cy });
        return {
          x: (best.cx - size / 2) - anchors[i].left,
          y: (best.cy - size / 2) - anchors[i].top,
          rot: best.rot,
        };
      });
      tl.to(imgs, {
        x: (i) => positions[i].x,
        y: (i) => positions[i].y,
        rotation: (i) => positions[i].rot,
        duration: 1.4,
        ease: 'power2.inOut',
      }, sceneT - 0.4);
    });
  }

  spawnShapes('aicosts-short', document.getElementById('shape-backdrop'));

  window.__timelines = window.__timelines || {};
  const tl = gsap.timeline({ paused: true });

  const TOTAL_DURATION = 112;

  // Ambient breath + progress bar
  tl.fromTo("#ambient",
    { opacity: 0.85, scale: 1.0 },
    { opacity: 1.0, scale: 1.04, duration: 30, ease: "sine.inOut", yoyo: true, repeat: 3 },
    0);
  tl.fromTo("#progress-fill",
    { width: 0 },
    { width: 1080, duration: TOTAL_DURATION, ease: "none" },
    0);
  tl.from("#top-banner", { y: -20, opacity: 0, duration: 0.6, ease: "power2.out" }, 0.2);

  function transition(from, to, T) {
    tl.to(from, { filter: "blur(20px)", scale: 1.04, duration: 0.5, ease: "power1.in" }, T);
    tl.to(from, { opacity: 0,                          duration: 0.4, ease: "power1.in" }, T + 0.3);
    tl.set(from, { visibility: "hidden" }, T + 0.7);
    tl.set(to,   { filter: "blur(20px)", scale: 0.97, opacity: 0, visibility: "visible" }, T + 0.4);
    tl.to(to,   { opacity: 1,                         duration: 0.3, ease: "power1.inOut", overwrite: "auto" }, T + 0.4);
    tl.to(to,   { filter: "blur(0px)", scale: 1,      duration: 0.5, ease: "power1.out",   overwrite: "auto" }, T + 0.6);
  }

  // ── PHASE 1 — 0..12s ──
  tl.from("#p1-overline",     { y: 20, opacity: 0, duration: 0.5, ease: "power2.out" }, 0.4);
  tl.from("#p1-invoice-card", { scale: 0.94, opacity: 0, duration: 0.7, ease: "back.out(1.5)" }, 0.6);
  const counterEl = document.getElementById('p1-counter');
  gsap.set(counterEl, { innerText: '$0' });
  tl.to({ v: 0 }, {
    v: 113421,
    duration: 2.2,
    ease: "power2.out",
    onUpdate: function() {
      const val = Math.round(this.targets()[0].v);
      counterEl.innerText = '$' + val.toLocaleString('en-US');
    }
  }, 3.2);
  tl.from("#p1-receipt-line", { y: 18, opacity: 0, duration: 0.5, ease: "power2.out" }, 6.5);
  tl.to("#p1-counter", { scale: 1.04, duration: 0.3, yoyo: true, repeat: 1, ease: "sine.inOut" }, 8.8);

  const T1 = 12.0;
  transition("#phase1", "#phase2", T1);

  // ── PHASE 2 — 12..24s ──
  const P2 = T1 + 0.8;
  tl.from("#p2-nvidia-mark", { y: 24, opacity: 0, duration: 0.5, ease: "power2.out" }, P2);
  tl.from("#p2-quote",       { y: 36, opacity: 0, duration: 0.7, ease: "power3.out" }, P2 + 0.5);
  tl.to("#p2-mark", { scaleX: 1, duration: 0.65, ease: "power2.out" }, P2 + 3.0);
  tl.from("#p2-attrib",      { y: 18, opacity: 0, duration: 0.5, ease: "power2.out" }, P2 + 5.0);
  tl.to(".farbeyond",        { scale: 1.05, duration: 0.3, yoyo: true, repeat: 1, ease: "sine.inOut", transformOrigin: "left center" }, P2 + 8.0);

  const T2 = 24.0;
  transition("#phase2", "#phase3", T2);

  // ── PHASE 3 — 24..36s ──
  const P3 = T2 + 0.8;
  tl.from("#p3-overline",      { y: 20, opacity: 0, duration: 0.5, ease: "power2.out" }, P3);
  tl.from("#p3-headline",      { y: 30, opacity: 0, duration: 0.6, ease: "power3.out" }, P3 + 0.4);
  tl.from("#p3-budget-frame",  { y: 24, opacity: 0, duration: 0.5, ease: "power2.out" }, P3 + 1.0);
  tl.to("#p3-budget-fill",     { width: "100%", duration: 1.5, ease: "power2.inOut" }, P3 + 1.6);
  tl.fromTo("#p3-budget-slam", { scale: 0.85, opacity: 0 }, { scale: 1.0, opacity: 1, duration: 0.5, ease: "back.out(1.6)" }, P3 + 3.2);
  tl.fromTo("#p3-r1", { x: -30, opacity: 0 }, { x: 0, opacity: 1, duration: 0.5, ease: "power2.out" }, P3 + 4.6);
  tl.fromTo("#p3-r2", { x: -30, opacity: 0 }, { x: 0, opacity: 1, duration: 0.5, ease: "power2.out" }, P3 + 6.4);
  tl.fromTo("#p3-r3", { x: -30, opacity: 0 }, { x: 0, opacity: 1, duration: 0.5, ease: "power2.out" }, P3 + 8.2);

  const T3 = 36.0;
  transition("#phase3", "#phase4", T3);

  // ── PHASE 4 — 36..50s — bar heights: max 600 ──
  const P4 = T3 + 0.8;
  tl.from("#p4-overline", { y: 20, opacity: 0, duration: 0.5, ease: "power2.out" }, P4);
  tl.from("#p4-headline", { y: 30, opacity: 0, duration: 0.6, ease: "power3.out" }, P4 + 0.4);
  tl.to("#p4-bar-1",  { height: 146, duration: 0.8, ease: "power2.out" }, P4 + 1.8);
  tl.to("#p4-num-1",  { opacity: 1, duration: 0.4 }, P4 + 2.6);
  tl.to("#p4-bar-2",  { height: 271, duration: 0.8, ease: "power2.out" }, P4 + 5.0);
  tl.to("#p4-num-2",  { opacity: 1, duration: 0.4 }, P4 + 5.8);
  tl.to("#p4-bar-3",  { height: 600, duration: 1.0, ease: "back.out(1.4)" }, P4 + 8.0);
  tl.fromTo("#p4-num-3", { scale: 0.7, opacity: 0 }, { scale: 1.0, opacity: 1, duration: 0.5, ease: "back.out(1.6)" }, P4 + 8.9);
  tl.from("#p4-caption", { y: 16, opacity: 0, duration: 0.5, ease: "power2.out" }, P4 + 10.0);
  tl.to("#p4-bar-3", { scale: 1.03, duration: 0.3, yoyo: true, repeat: 1, ease: "sine.inOut", transformOrigin: "bottom center" }, P4 + 11.5);

  const T4 = 50.0;
  transition("#phase4", "#phase5", T4);

  // ── PHASE 5 — 50..60s ──
  const P5 = T4 + 0.8;
  tl.from("#p5-overline", { y: 20, opacity: 0, duration: 0.5, ease: "power2.out" }, P5);
  tl.from("#p5-pill",     { scale: 0.86, opacity: 0, duration: 0.8, ease: "back.out(1.6)" }, P5 + 0.5);
  const p5num = document.getElementById('p5-num');
  gsap.set(p5num, { innerText: '$0' });
  tl.to({ v: 0 }, {
    v: 28,
    duration: 1.4,
    ease: "power2.out",
    onUpdate: function() {
      const val = Math.round(this.targets()[0].v);
      p5num.innerText = '$' + val + 'K';
    }
  }, P5 + 1.5);
  tl.from("#p5-sub", { y: 24, opacity: 0, duration: 0.5, ease: "power2.out" }, P5 + 3.5);
  tl.to("#p5-pill", { scale: 1.02, duration: 0.3, yoyo: true, repeat: 1, ease: "sine.inOut" }, P5 + 6.0);
  tl.to("#p5-num", { scale: 1.04, duration: 0.3, yoyo: true, repeat: 1, ease: "sine.inOut" }, P5 + 7.8);

  const T5 = 60.0;
  transition("#phase5", "#phase6", T5);

  // ── PHASE 6 — 60..72s ──
  const P6 = T5 + 0.8;
  tl.from("#p6-overline", { y: 20, opacity: 0, duration: 0.5, ease: "power2.out" }, P6);
  tl.from("#p6-pill",     { scale: 0.86, opacity: 0, duration: 0.8, ease: "back.out(1.6)" }, P6 + 0.5);
  tl.from("#p6-label",    { y: 18, opacity: 0, duration: 0.5, ease: "power2.out" }, P6 + 2.0);
  tl.from("#p6-sub",      { y: 14, opacity: 0, duration: 0.4, ease: "power2.out" }, P6 + 3.0);
  tl.fromTo("#p6-layoffs", { y: 24, opacity: 0 }, { y: 0, opacity: 1, duration: 0.5, ease: "power2.out" }, P6 + 4.5);
  const layoffEl = document.getElementById('p6-layoffs-num');
  gsap.set(layoffEl, { innerText: '0' });
  tl.to({ v: 0 }, {
    v: 92000,
    duration: 2.4,
    ease: "power2.out",
    onUpdate: function() {
      const val = Math.round(this.targets()[0].v);
      layoffEl.innerText = val.toLocaleString('en-US');
    }
  }, P6 + 5.0);
  tl.to("#p6-layoffs-num", { scale: 1.05, duration: 0.3, yoyo: true, repeat: 1, ease: "sine.inOut" }, P6 + 7.7);

  const T6 = 72.0;
  transition("#phase6", "#phase7", T6);

  // ── PHASE 7 — 72..86s ──
  const P7 = T6 + 0.8;
  tl.from("#p7-overline", { y: 20, opacity: 0, duration: 0.5, ease: "power2.out" }, P7);
  tl.from("#p7-headline", { y: 28, opacity: 0, duration: 0.6, ease: "power3.out" }, P7 + 0.4);

  // Dot 1 + label 1 — line starts drawing
  tl.to("#p7-dot-1",   { opacity: 1, duration: 0.3, ease: "power2.out" }, P7 + 1.8);
  tl.fromTo("#p7-label-1", { x: -16, opacity: 0 }, { x: 0, opacity: 1, duration: 0.5, ease: "power2.out" }, P7 + 1.9);

  // Polyline segment 1: dot-1 → dot-2 (length ≈ 464, total dasharray 1000)
  tl.fromTo("#p7-polyline",
    { strokeDashoffset: 1000 },
    { strokeDashoffset: 536, duration: 3.0, ease: "power1.out" },
    P7 + 2.0);

  // Dot 2 + label 2 — line reaches midpoint
  tl.to("#p7-dot-2",   { opacity: 1, duration: 0.3, ease: "power2.out" }, P7 + 5.0);
  tl.fromTo("#p7-label-2", { y: -12, opacity: 0 }, { y: 0, opacity: 1, duration: 0.5, ease: "power2.out" }, P7 + 5.1);

  // Polyline segment 2: dot-2 → dot-3
  tl.to("#p7-polyline",
    { strokeDashoffset: 0, duration: 3.0, ease: "power1.out", overwrite: "auto" },
    P7 + 5.2);

  // Dot 3 + label 3 — line reaches endpoint
  tl.to("#p7-dot-3",   { opacity: 1, duration: 0.3, ease: "power2.out" }, P7 + 8.2);
  tl.fromTo("#p7-label-3", { x: 16, opacity: 0 }, { x: 0, opacity: 1, duration: 0.5, ease: "power2.out" }, P7 + 8.3);

  tl.from("#p7-caption",  { y: 16, opacity: 0, duration: 0.5, ease: "power2.out" }, P7 + 9.6);
  tl.to("#p7-dot-3", { attr: { r: 26 }, duration: 0.3, yoyo: true, repeat: 1, ease: "sine.inOut" }, P7 + 11.4);

  const T7 = 86.0;
  transition("#phase7", "#phase8", T7);

  // ── PHASE 8 — 86..98s ──
  const P8 = T7 + 0.8;
  tl.from("#p8-overline", { y: 20, opacity: 0, duration: 0.5, ease: "power2.out" }, P8);
  tl.from("#p8-pill",     { scale: 0.86, opacity: 0, duration: 0.8, ease: "back.out(1.6)" }, P8 + 0.5);
  const p8num = document.getElementById('p8-num');
  gsap.set(p8num, { innerText: '0%' });
  tl.to({ v: 0 }, {
    v: 95,
    duration: 1.6,
    ease: "power2.out",
    onUpdate: function() {
      const val = Math.round(this.targets()[0].v);
      p8num.innerText = val + '%';
    }
  }, P8 + 1.4);
  tl.from("#p8-label", { y: 18, opacity: 0, duration: 0.5, ease: "power2.out" }, P8 + 3.4);
  tl.from("#p8-sub",   { y: 14, opacity: 0, duration: 0.4, ease: "power2.out" }, P8 + 4.4);
  tl.to("#p8-num",  { scale: 1.05, duration: 0.3, yoyo: true, repeat: 1, ease: "sine.inOut" }, P8 + 6.4);
  tl.to("#p8-pill", { scale: 1.02, duration: 0.3, yoyo: true, repeat: 1, ease: "sine.inOut" }, P8 + 9.0);

  const T8 = 98.0;
  transition("#phase8", "#phase9", T8);

  // ── PHASE 9 — 98..112s — Thumbnail close ──
  const P9 = T8 + 0.8;
  tl.from("#p9-brand-row", { y: 18, opacity: 0, duration: 0.5, ease: "power2.out" }, P9);
  tl.from("#p9-slam",      { scale: 0.86, opacity: 0, duration: 0.8, ease: "back.out(1.6)" }, P9 + 0.4);
  tl.from("#p9-receipts",  { y: 20, opacity: 0, duration: 0.5, ease: "power2.out" }, P9 + 1.4);
  tl.from("#cta-question", { y: 24, opacity: 0, duration: 0.6, ease: "power2.out" }, P9 + 2.2);
  tl.from("#p9-cta-pill",  { y: 18, opacity: 0, duration: 0.5, ease: "power2.out" }, P9 + 3.0);
  tl.to("#p9-slam .b1", { scale: 1.04, duration: 0.4, yoyo: true, repeat: 1, ease: "sine.inOut" }, P9 + 4.6);
  tl.to("#p9-slam .b2", { scale: 1.04, duration: 0.4, yoyo: true, repeat: 1, ease: "sine.inOut" }, P9 + 5.6);
  tl.to("#cta-question", { scale: 1.02, duration: 0.4, yoyo: true, repeat: 1, ease: "sine.inOut" }, P9 + 7.0);

  // Pin timeline to TOTAL_DURATION
  tl.set({}, {}, TOTAL_DURATION);

  repositionShapesPerPhase(
    tl,
    document.getElementById('shape-backdrop'),
    'aicosts-short',
    [T1, T2, T3, T4, T5, T6, T7, T8]
  );

  window.__timelines["main"] = tl;
</script>
</body>
</html>
