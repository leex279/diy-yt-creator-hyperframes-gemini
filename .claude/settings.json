{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/log-run.py user_prompt",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/sync-shared-assets.sh",
            "timeout": 10,
            "statusMessage": "Syncing shared/ASSETS.md"
          },
          {
            "type": "command",
            "command": "bash scripts/sync-shared-lib.sh",
            "timeout": 10,
            "statusMessage": "Syncing shared/lib/MANIFEST.md"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/log-run.py post_tool_use",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/log-run.py stop",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/sync-shared-assets.sh",
            "timeout": 10,
            "statusMessage": "Syncing shared/ASSETS.md"
          },
          {
            "type": "command",
            "command": "bash scripts/sync-shared-lib.sh",
            "timeout": 10,
            "statusMessage": "Syncing shared/lib/MANIFEST.md"
          }
        ]
      }
    ]
  }
}
