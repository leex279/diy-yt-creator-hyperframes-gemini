  "chunks": [
    {
      "index": 0,
      "text": "Anthropic just signed a partnership with SpaceX.",
      "checksum": "sha256:86cec3bdc54925e1d618094e5956485e1eb91d1939c273e2baf471a25867a86e",
      "wav": "chunk-00.wav",
      "duration": 2.693514739229025,
      "word_count": 7,
      "words_offset": 0
    },
    {
      "index": 1,
      "text": "The announcement dropped today, May 6th, 2026.",
      "checksum": "sha256:378334c0506bd4375afe56654828814665f6772f6367656784c37485b434e4a3",
      "wav": "chunk-01.wav",
      "duration": 3.297233560090703,
      "word_count": 7,
      "words_offset": 7
    },
    {
      "index": 2,
      "text": "Three rate limits change effective immediately.",
      "checksum": "sha256:eeba16aa04398665a3e9a9e99c5214c31268d831eaa7d031521283bbc3b2a225",
      "wav": "chunk-02.wav",
      "duration": 2.414875283446712,
      "word_count": 6,
      "words_offset": 14
    },
    {
      "index": 3,
      "text": "Claude Code just got DOUBLED. The deal locks in all of SpaceX's Colossus 1 data center.",
      "checksum": "sha256:3416682943fff0b32657a481e2572cc9aaaacec8d2bce88a93087af02dd411e5",
      "wav": "chunk-03.wav",
      "duration": 5.340589569160998,
      "word_count": 16,
      "words_offset": 20
    },
    {
      "index": 4,
      "text": "Over 300 megawatts of new capacity. 220,000 NVIDIA GPUs.",
      "checksum": "sha256:37466db34dd574708e3188ec2657f4ed46208b88bce1e688c7209ef86ca63ce7",
      "wav": "chunk-04.wav",
      "duration": 4.96907029478458,
      "word_count": 9,
      "words_offset": 36
    },
    {
      "index": 5,
      "text": "All coming online within one month. What changed effective today.",
      "checksum": "sha256:6e2f6517a490485b942e214170ed3338ddb4d14193d90d98ac3eae6004262b96",
      "wav": "chunk-05.wav",
      "duration": 3.622312925170068,
      "word_count": 10,
      "words_offset": 45
    },
    {
      "index": 6,
      "text": "One. Doubled 5-hour rate limits for Pro, Max, Team, and Enterprise plans.",
      "checksum": "sha256:de226698202998ed69f704e5e36e34b6a6e2fb3ae0af4e7cd2f6c4924dc1e4bd",
      "wav": "chunk-06.wav",
      "duration": 4.597551020408163,
      "word_count": 12,
      "words_offset": 55
    },
    {
      "index": 7,
      "text": "Two. Peak hours limit reduction removed for Pro and Max accounts.",
      "checksum": "sha256:e40a1f541fe11ef43dca30aedbe88d14a2ddde6bc188841f1786350b142ab51a",
      "wav": "chunk-07.wav",
      "duration": 4.365351473922902,
      "word_count": 11,
      "words_offset": 67
    },
    {
      "index": 8,
      "text": "Three. Opus API rate limits raised considerably.",
      "checksum": "sha256:769f41cb151a08f08cd7bd92a993ec132ff3482ad491db22f95141ac8606f8d7",
      "wav": "chunk-08.wav",
      "duration": 2.9257142857142857,
      "word_count": 7,
      "words_offset": 78
    },
    {
      "index": 9,
      "text": "This sits alongside compute deals with Amazon, Google, Microsoft, NVIDIA, and Fluidstack.",
      "checksum": "sha256:4f396285f1caa9b121f2073ec6e4bca2abd64f0e39ef858abbd8ac0794e66bc5",
      "wav": "chunk-09.wav",
      "duration": 5.712108843537415,
      "word_count": 12,
      "words_offset": 85
    },
    {
      "index": 10,
      "text": "Read the full announcement at anthropic dot com slash news slash higher limits spacex.",
      "checksum": "sha256:9436be37bddf996e47cfb8a86e1ee39aa656f86018f90c0b37754b7e478e5481",
      "wav": "chunk-10.wav",
      "duration": 4.4117913832199545,
