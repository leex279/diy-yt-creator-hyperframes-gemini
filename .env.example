# ElevenLabs TTS — used by scripts/elevenlabs-tts.py and scripts/generate-sfx-library.py
# Copy to .env and fill in real values. .env is gitignored; .env.example is committed.

# --- Auth ---
ELEVENLABS_API_KEY=sk_your_key_here

# --- Voice ---
# Find voice_id in the ElevenLabs dashboard → Voices → (voice) → ID.
ELEVENLABS_VOICE_ID=
# Model. Note: pronunciation dictionaries (below) work best with
# eleven_turbo_v2, eleven_turbo_v2_5, eleven_monolingual_v1, eleven_multilingual_v1.
# eleven_multilingual_v2 / eleven_v3 have limited dictionary support (alias-style only).
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# --- Voice settings (floats 0.0–1.0 unless noted) ---
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0.0
ELEVENLABS_USE_SPEAKER_BOOST=true

# Speed: 1.0 = natural. Shorts use a slightly different speed via --shorts.
ELEVENLABS_SPEED=1.0
ELEVENLABS_SPEED_SHORTS=1.05

# --- Pronunciation dictionary (optional) ---
# ElevenLabs dictionaries do NOT auto-apply from your account — they must be
# attached per request via locators. Both ID and VERSION_ID are required.
# Get the version_id with:
#   client.pronunciation_dictionaries.get(pronunciation_dictionary_id="<id>")
# and read `latest_version_id` from the response.
ELEVENLABS_PRONUNCIATION_DICT_ID=
ELEVENLABS_PRONUNCIATION_DICT_VERSION_ID=
